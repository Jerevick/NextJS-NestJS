JWT_SECRET=change-me-access-token-signing-secret-min-16-chars
# AES-256-GCM for sensitive JSON fields (e.g. staff salary). Falls back to JWT_SECRET if unset.
# FIELD_ENCRYPTION_KEY=change-me-field-encryption-secret-min-32-chars
# Blind election voter hashing (falls back to JWT_SECRET)
# ELECTION_VOTING_SECRET=change-me-election-voting-secret-min-32-chars
# AI meeting minutes (optional — heuristic fallback when unset)
# OPENAI_API_KEY=
# OPENAI_MINUTES_MODEL=gpt-4o-mini
# MEETINGS_DEFAULT_LINK=https://teams.microsoft.com/l/meetup-join/placeholder
# Zoom Server-to-Server OAuth (optional — tried before Google/Teams calendar)
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# Zoom Meeting SDK (browser embed; defaults to ZOOM_CLIENT_ID/SECRET)
# ZOOM_SDK_KEY=
# ZOOM_SDK_SECRET=
# PGVECTOR_ENABLED=1
# BILLING_ANOMALY_WEBHOOK_URL=https://hooks.example.com/billing-anomaly
# RSA blind-signature keys for election booth (generate 2048-bit PEM pair; dev auto-generates if unset)
# ELECTION_RSA_PRIVATE_KEY_PEM=
# ELECTION_RSA_PUBLIC_KEY_PEM=
# AI Phase 13 (optional)
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# Calendar OAuth (optional — enables push on leave approval)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# MICROSOFT_CALENDAR_CLIENT_ID=
# MICROSOFT_CALENDAR_CLIENT_SECRET=
# MICROSOFT_CALENDAR_TENANT=common
# API_PUBLIC_URL=http://localhost:4000
# WEB_PUBLIC_URL=http://localhost:3000
JWT_REFRESH_SECRET=change-me-refresh-token-signing-secret-min-16
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..G9ZjHPo3Mhz8hCUxZ4rumYpraV_ICArT6tBDW2VGM1A
# Optional: BullMQ (entity provisioning + billing jobs). If unset, jobs run synchronously in-process.
# REDIS_URL=redis://127.0.0.1:6379
# Per-seat USD when no Subscription row exists (draft invoices).
BILLING_DEFAULT_UNIT_USD=12.00
# Billing evidence JSON (local fallback when S3 is not configured).
# BILLING_EVIDENCE_DIR=.storage/billing-evidence
# AWS_S3_BUCKET=unicore-billing
# AWS_REGION=us-east-1
# AWS_S3_ENDPOINT=http://127.0.0.1:9000
PORT=4000
APP_ROOT_DOMAIN=localhost
