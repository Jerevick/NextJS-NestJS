{
  "name": "@unicore/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\""
  },
  "devDependencies": {
    "@unicore/eslint-config": "workspace:*",
    "@unicore/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "tsup": "^8.3.5",
    "typescript": "catalog:"
  }
}
