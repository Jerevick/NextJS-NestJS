/** Buffered LOW-priority outbound notifications for hourly digest email. */
model NotificationDigestEntry {
  id            String   @id @default(cuid())
  institutionId String
  userId        String
  event         String
  channels      String[] @default([])
  subject       String
  title         String
  body          String
  htmlBody      String?
  textBody      String?
  actionUrl     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([institutionId, userId])
}

enum ScheduledNotificationStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

enum ScheduledNotificationKind {
  SINGLE
  BULK
}

/** Future delivery via BullMQ delayed job (Phase 14.1). */
model ScheduledNotification {
  id            String                      @id @default(cuid())
  institutionId String
  entityId      String?
  initiatedById String
  kind          ScheduledNotificationKind
  recipientId   String?
  event         String?
  payload       Json
  scheduledAt   DateTime
  status        ScheduledNotificationStatus @default(PENDING)
  bullJobId     String?
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)
  initiator   User               @relation("ScheduledNotificationInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)
  recipient   User?              @relation("ScheduledNotificationRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([institutionId, status, scheduledAt])
  @@index([status, scheduledAt])
}

