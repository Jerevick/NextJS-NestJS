  program     Program @relation(fields: [programId], references: [id], onDelete: Restrict)
  initiator   User @relation("FinanceBulkChargeInitiator", fields: [initiatedById], references: [id], onDelete: Restrict)

  @@index([institutionId, status])
  @@index([initiatedById])
}

enum NotificationPriority {
  HIGH
  NORMAL
  LOW
}

model NotificationTemplate {
  id            String   @id @default(cuid())
  institutionId String?
  entityId      String?
  event         String
  channels      Json     @default("{\"email\":true,\"inApp\":true}")
  subject       String?
  htmlBody      String?
  textBody      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution?       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([institutionId, entityId, event])
}

model UserNotification {
  id            String               @id @default(cuid())
  institutionId String
  entityId      String?
  userId        String
  event         String?
  category      String
  title         String
  body          String
  actionUrl     String?
  channels      String[]             @default([])
  priority      NotificationPriority @default(NORMAL)
  readAt        DateTime?
  metadata      Json?
  createdAt     DateTime             @default(now())

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([institutionId, userId, createdAt])
  @@index([institutionId, event])
