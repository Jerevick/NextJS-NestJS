model FinanceScholarshipAward {
  id                 String             @id @default(cuid())
  institutionId      String
  entityId           String
  scholarshipId      String
  studentId          String
  amount             Decimal            @db.Decimal(14, 2)
  academicYearId     String
  status             FinanceAwardStatus @default(PENDING)
  workflowInstanceId String?
  awardedBy          String?
  disbursedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  institution  Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity       InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  scholarship  FinanceScholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@index([institutionId, studentId])
  @@index([scholarshipId])
}

model FinanceBankIntegration {
  id            String   @id @default(cuid())
  institutionId String
  entityId      String
  provider      String
  config        Json     @default("{}")
  isActive      Boolean  @default(true)
  webhookSecret String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)

  @@index([institutionId, entityId, provider])
}

enum FinanceBulkChargeJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model FinanceBulkChargeJob {
  id            String                     @id @default(cuid())
  institutionId String
  entityId      String
  programId     String
  initiatedById String
  amount        Decimal                    @db.Decimal(14, 2)
