model FeeStructure {
  id             String    @id @default(cuid())
  institutionId  String
  entityId       String
  name           String
  academicYearId String
  programmeIds   String[]  @default([])
  isDefault      Boolean   @default(false)
  items          Json      @default("[]")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  institution  Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity       InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  academicYear AcademicYear      @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@index([institutionId, entityId])
  @@index([institutionId, academicYearId])
}

model StudentAccount {
  id                String    @id @default(cuid())
  institutionId     String
  entityId          String
  studentId         String    @unique
  balance           Decimal   @default(0) @db.Decimal(14, 2)
  currency          String    @default("USD")
  lastTransactionAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  institution  Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity       InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions FinanceTransaction[]
  paymentPlans FinancePaymentPlan[]

  @@index([institutionId, entityId])
}

model FinanceTransaction {
  id                    String                   @id @default(cuid())
  institutionId         String
  entityId              String
  studentAccountId      String
  type                  FinanceTransactionType
  amount                Decimal                  @db.Decimal(14, 2)
  currency              String
  description           String
  reference             String                   @unique
  paymentMethod         String?
  gatewayRef            String?
  gatewayResponse       Json?
  status                FinanceTransactionStatus
  processedAt           DateTime?
  processedBy           String?
  approvedBy            String?
  approvalWorkflowId    String?
  /** Double-entry ledger pairs + extensibility (Phase 9). */
  metadata              Json                     @default("{}")
  isReversed            Boolean                  @default(false)
  reversedTransactionId String?
  createdAt             DateTime                 @default(now())

  institution    Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity         InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  studentAccount StudentAccount    @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  glJournalLines FinanceGlJournalLine[]

  @@index([institutionId, studentAccountId, createdAt])
  @@index([institutionId, entityId])
}

/** Institution chart of accounts (student finance GL). */
model FinanceGlAccount {
  id            String               @id @default(cuid())
  institutionId String
  code          String
  name          String
  type          FinanceGlAccountType
  normalBalance FinanceGlNormalBalance
  isSystem      Boolean              @default(false)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, code])
  @@index([institutionId, isActive])
}

/** Immutable GL lines posted from completed finance transactions. */
model FinanceGlJournalLine {
  id                     String   @id @default(cuid())
  institutionId          String
  entityId               String
  financeTransactionId   String
  accountCode            String
  debit                  Decimal  @db.Decimal(14, 2)
  credit                 Decimal  @db.Decimal(14, 2)
  postedAt               DateTime @default(now())

  institution        Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  financeTransaction FinanceTransaction @relation(fields: [financeTransactionId], references: [id], onDelete: Cascade)

  @@index([institutionId, financeTransactionId])
  @@index([institutionId, accountCode, postedAt])
}

model FinancePaymentPlan {
  id               String                   @id @default(cuid())
  institutionId    String
  entityId         String
  studentAccountId String
  totalAmount      Decimal                  @db.Decimal(14, 2)
  currency         String
  installments     Json                     @default("[]")
  status           FinancePaymentPlanStatus @default(ACTIVE)
  createdBy        String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  institution    Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity         InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  studentAccount StudentAccount    @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)

  @@index([institutionId, studentAccountId])
}

model FinanceScholarship {
  id                  String                 @id @default(cuid())
  institutionId       String
  entityId            String
  name                String
  type                FinanceScholarshipType
  fundingSource       String
  totalFund           Decimal                @db.Decimal(14, 2)
  disbursedAmount     Decimal                @default(0) @db.Decimal(14, 2)
  conditions          Json                   @default("{}")
  applicationSchemaId String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  awards       FinanceScholarshipAward[]
  applications FinanceScholarshipApplication[]

  @@index([institutionId, entityId])
}

model FinanceScholarshipApplication {
  id            String                            @id @default(cuid())
  institutionId String
  entityId      String
  scholarshipId String
  studentId     String
  responses     Json                              @default("{}")
  status        FinanceScholarshipApplicationStatus @default(SUBMITTED)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes          String?
