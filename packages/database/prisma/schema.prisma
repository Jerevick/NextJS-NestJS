  LIABILITY
  REVENUE
  EXPENSE
}

enum FinanceGlNormalBalance {
  DEBIT
  CREDIT
}

enum FinanceTransactionType {
  CHARGE
  PAYMENT
  SCHOLARSHIP_CREDIT
  REFUND
  ADJUSTMENT
  WAIVER
}

enum FinanceTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
  CANCELLED
}

enum FinancePaymentPlanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum FinanceScholarshipType {
  MERIT
  NEED_BASED
  ATHLETIC
  SPONSORED
  OTHER
}

enum FinanceAwardStatus {
  PENDING
  APPROVED
  DISBURSED
  REVOKED
}

enum FinanceScholarshipApplicationStatus {
