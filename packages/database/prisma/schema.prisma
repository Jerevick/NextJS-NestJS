  PENDING
  CONFIRMED
  CANCELLED
}

enum CompetitionType {
  LEAGUE
  TOURNAMENT
  FRIENDLY
  CHAMPIONSHIP
}

enum CompetitionStatus {
  PLANNED
  IN_PROGRESS
