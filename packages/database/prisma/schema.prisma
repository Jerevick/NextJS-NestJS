  organizer   User?              @relation("SportsCompetitionOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  entries     SportsCompetitionEntry[]
  fixtures    SportsFixture[]

  @@index([institutionId, status])
}

model SportsCompetitionEntry {
  id            String   @id @default(cuid())
  institutionId String
  competitionId String
  teamId        String
  registeredAt  DateTime @default(now())
  allEligible   Boolean  @default(true)
  notes         String?

  institution Institution     @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  competition SportsCompetition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  team        SportsTeam        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([competitionId, teamId])
  @@index([institutionId, competitionId])
}

model SportsAward {
  id            String   @id @default(cuid())
  institutionId String
  entityId      String?
  title         String
  description   String?
  sportTypeId   String?
  teamId        String?
  playerId      String?
  academicYear  String?
  awardedAt     DateTime @default(now())
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([institutionId, awardedAt])
}

model SportsRecord {
  id            String   @id @default(cuid())
  institutionId String
  entityId      String?
  category      String
  title         String
  value         String
  holderName    String?
  sportTypeId   String?
  setAt         DateTime @default(now())
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([institutionId, category])
}

model SportsFixture {
  id            String        @id @default(cuid())
  institutionId String
  entityId      String?
  competitionId String?
  homeTeamId    String
  awayTeamId    String
  scheduledAt   DateTime
  venue         String?
  status        FixtureStatus @default(SCHEDULED)
  score         Json?
  statistics    Json?
  matchReport   String?
  streamUrl     String?
  logistics     Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  entity      InstitutionEntity? @relation(fields: [entityId], references: [id], onDelete: SetNull)
  competition SportsCompetition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  homeTeam    SportsTeam           @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam    SportsTeam           @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)

  @@index([institutionId, scheduledAt])
  @@index([competitionId])
}

/// Phase 13 — RAG document chunks (embedding stored as JSON number[]; pgvector optional upgrade).
model EmbeddingDocument {
  id            String   @id @default(cuid())
  institutionId String
  entityId      String?
  sourceType    String
  sourceId      String
  content       String
  metadata      Json?
  embedding        Json
  /// Native pgvector column (1536-dim); synced when PGVECTOR_ENABLED=1.
  embeddingVector  Unsupported("vector(1536)")?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([institutionId, sourceType, sourceId])
  @@index([institutionId, entityId, sourceType])
}
