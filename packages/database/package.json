{
  "name": "@unicore/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma": "prisma",
    "db:migrate": "pnpm -w db:migrate",
    "db:seed": "pnpm -w db:seed",
    "db:generate": "pnpm -w db:generate",
    "db:studio": "pnpm -w db:studio",
    "migrate:deploy": "pnpm -w db:migrate:deploy",
    "test": "pnpm -w test",
    "clean": "node -e \"const fs=require('fs');['dist'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "@unicore/eslint-config": "workspace:*",
    "@unicore/typescript-config": "workspace:*",
    "bcryptjs": "^2.4.3",
    "eslint": "catalog:",
    "prisma": "6.19.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
