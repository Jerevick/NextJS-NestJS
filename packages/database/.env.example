# Prisma CLI reads this file from packages/database/ (same folder as prisma/)
# Copy to .env or set DATABASE_URL in your shell before migrate.
# Copy to packages/database/.env (required for pnpm db:migrate from repo root)

# Local Docker (recommended for migrate dev + seed):
DATABASE_URL="postgresql://unicore:unicore@127.0.0.1:15432/unicore?schema=public"
DIRECT_DATABASE_URL="postgresql://unicore:unicore@127.0.0.1:15432/unicore?schema=public"

# Prisma Accelerate (runtime only — migrate dev needs DIRECT_DATABASE_URL to real Postgres):
# DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=..."
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
