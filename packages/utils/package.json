{
  "name": "@unicore/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./election-blind-rsa-browser": {
      "types": "./dist/election-blind-rsa-browser.d.ts",
      "import": "./dist/election-blind-rsa-browser.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/election-blind-rsa-browser.ts --format esm,cjs --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\""
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@unicore/eslint-config": "workspace:*",
    "@unicore/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "tsup": "^8.3.5",
    "typescript": "catalog:"
  }
}
