{
  "name": "@unicore/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts --external react --external react-dom --external @mui/material --external @mui/material-nextjs --external @mui/x-data-grid --external @mui/system --external @emotion/react --external @emotion/styled --external @emotion/cache --clean",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@unicore/eslint-config": "workspace:*",
    "@unicore/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^6.5.0",
    "@mui/material-nextjs": "^6.5.0",
    "@mui/system": "^6.4.11",
    "@mui/x-data-grid": "^7.29.13"
  }
}
